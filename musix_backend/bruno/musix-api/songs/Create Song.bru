meta {
  name: Create Song
  type: http
}

post {
  url: {{baseUrl}}/songs/create
  body: json
  auth: bearer
}

body:json {
  {
    "title": "New Song",
    "artist": "Artist Name",
    "audio_url": "/uploads/audio/song.mp3",
    "cover_url": "/uploads/covers/cover.jpg"
  }
}

auth:bearer {
  token: {{token}}
}
